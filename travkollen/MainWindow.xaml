<Window x:Class="travkollen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:travkollen"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <Grid>
        <TextBox x:Name="txtDateOfBirth" HorizontalAlignment="Left" Margin="121,60,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="175"/>
        <TextBox x:Name="txtNameOfPerson" HorizontalAlignment="Left" Margin="121,23,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="175"/>
        <TextBlock HorizontalAlignment="Left" Margin="22,23,0,0" TextWrapping="Wrap" Text="Namn:" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="22,60,0,0" TextWrapping="Wrap" Text="Födelsedatum:" VerticalAlignment="Top"/>
        <Button x:Name="btnAddPerson" Content="Lägg till person" HorizontalAlignment="Left" Margin="211,99,0,0" VerticalAlignment="Top" Width="85" Click="btnAddPerson_Click"/>
        <Button x:Name="btnUpdatePerson" Content="Uppdatera" HorizontalAlignment="Left" Margin="121,99,0,0" VerticalAlignment="Top" Width="78" Click="btnUpdatePerson_Click" />
        <ComboBox x:Name="cbHorseSelector" HorizontalAlignment="Left" Margin="399,11,0,0" VerticalAlignment="Top" Width="368" SelectionChanged="cbHorseSelector_SelectionChanged"/>
        <TextBlock x:Name="tbHorseName" HorizontalAlignment="Left" Margin="400,187,0,0" TextWrapping="Wrap" Text="Namn:" VerticalAlignment="Top" Width="48"/>
        <TextBlock x:Name="tbHorseAge" HorizontalAlignment="Left" Margin="400,208,0,0" TextWrapping="Wrap" Text="Ålder:" VerticalAlignment="Top" Width="48"/>
        <TextBlock x:Name="tbTrainerName" HorizontalAlignment="Left" Margin="400,236,0,0" TextWrapping="Wrap" Text="Tränarnamn:" VerticalAlignment="Top" Width="74"/>
        <TextBlock x:Name="tbTrainerTrack" HorizontalAlignment="Left" Margin="400,260,0,0" TextWrapping="Wrap" Text="Hammabana:" VerticalAlignment="Top" Width="99"/>
        <TextBlock x:Name="tbSireName" HorizontalAlignment="Left" Margin="400,311,0,0" TextWrapping="Wrap" Text="Sire:" VerticalAlignment="Top" Width="99"/>
        <TextBlock x:Name="tbDamName" HorizontalAlignment="Left" Margin="400,347,0,0" TextWrapping="Wrap" Text="Dam:" VerticalAlignment="Top" Width="99"/>
        <TextBox x:Name="txtHorseName" HorizontalAlignment="Left" Margin="480,187,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="288"/>
        <TextBox x:Name="txtHorseAge" HorizontalAlignment="Left" Margin="480,210,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="288"/>
        <TextBox x:Name="txtTrainerName" HorizontalAlignment="Left" Margin="480,236,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="288"/>
        <TextBox x:Name="txtTrack" HorizontalAlignment="Left" Margin="480,260,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="288"/>
        <Button x:Name="btnDeleteHorse" Content="Ta bort häst" HorizontalAlignment="Left" Margin="480,417,0,0" FontWeight="Bold" Foreground="White" Background="IndianRed" VerticalAlignment="Top" Width="114" Click="btnDeleteHorse_Click"/>
        <Image x:Name="imgHorse" HorizontalAlignment="Left" Height="108" Margin="537,60,0,0" VerticalAlignment="Top" Width="144"/>
        <ComboBox x:Name="cbSire" HorizontalAlignment="Left" Margin="480,311,0,0" VerticalAlignment="Top" Width="288"/>
        <ComboBox x:Name="cbDam" HorizontalAlignment="Left" Margin="480,347,0,0" VerticalAlignment="Top" Width="288"/>
        <Button x:Name="btnSaveHorse" Background="ForestGreen" Foreground="White" FontWeight="Bold" Content="Uppdatera häst" HorizontalAlignment="Left" Margin="625,417,0,0" VerticalAlignment="Top" Width="143" Click="btnSaveHorse_Click_1"/>
        <TextBlock x:Name="tbTrainer" HorizontalAlignment="Left" Margin="400,383,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="99"><Run Language="sv-se" Text="Tränare"/><Run Text=":"/></TextBlock>
        <ComboBox x:Name="cbTrainer" HorizontalAlignment="Left" Margin="480,383,0,0" VerticalAlignment="Top" Width="288"/>

    </Grid>
</Window>
